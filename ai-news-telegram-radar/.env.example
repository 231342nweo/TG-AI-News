# Create a bot with @BotFather, add it as an admin to your channel,
# then fill these two values.
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=@your_channel_username

# Optional: set to false in code if you want link previews.
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true

# Optional: enable automatic Chinese translation for titles/summaries.
# Create a key at https://platform.openai.com/api-keys
# If using LiteLLM Virtual Keys, put your LiteLLM Proxy root or /v1 URL here.
# Do not use the admin UI URL. Good: https://your-litellm.example.com or https://your-litellm.example.com/v1
OPENAI_API_KEY=sk-replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_TRANSLATION_API=chat
OPENAI_TRANSLATION_ENABLED=1

# Optional: enable TikHub WeChat supplemental collection.
TIKHUB_API_KEY=replace_me
TIKHUB_POLL_MINUTES=60
